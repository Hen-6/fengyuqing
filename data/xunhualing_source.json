[
  {
    "id": "lbj1n5k2m",
    "title": "静夜思",
    "dynasty": "唐",
    "author": "李白",
    "type": "五言",
    "lines": [
      "床前明月光",
      "疑是地上霜",
      "举头望明月",
      "低头思故乡"
    ]
  },
  {
    "id": "wzh8j2k4l",
    "title": "登鹳雀楼",
    "dynasty": "唐",
    "author": "王之涣",
    "type": "五言",
    "lines": [
      "白日依山尽",
      "黄河入海流",
      "欲穷千里目",
      "更上一层楼"
    ]
  },
  {
    "id": "lb7k9j3m2",
    "title": "望庐山瀑布",
    "dynasty": "唐",
    "author": "李白",
    "type": "七言",
    "lines": [
      "日照香炉生紫烟",
      "遥看瀑布挂前川",
      "飞流直下三千尺",
      "疑是银河落九天"
    ]
  },
  {
    "title": "春晓",
    "dynasty": "唐",
    "author": "孟浩然",
    "type": "五言",
    "lines": [
      "春眠不觉晓",
      "处处闻啼鸟",
      "夜来风雨声",
      "花落知多少"
    ],
    "id": "mgiuavrfuohqg"
  },
  {
    "title": "咏鹅",
    "dynasty": "唐",
    "author": "骆宾王",
    "type": "五言",
    "lines": [
      "鹅鹅鹅",
      "曲项向天歌",
      "白毛浮绿水",
      "红掌拨清波"
    ],
    "id": "mgiubgoj6t5cx"
  },
  {
    "title": "赋得古原草送别",
    "dynasty": "唐",
    "author": "白居易",
    "type": "五言",
    "lines": [
      "离离原上草",
      "一岁一枯荣",
      "野火烧不尽",
      "春风吹又生",
      "远芳侵古道",
      "晴翠接荒城",
      "又送王孙去",
      "萋萋满别情"
    ],
    "id": "mgiuctkrsvpwe"
  },
  {
    "title": "长歌行",
    "dynasty": "汉",
    "author": "乐府诗集",
    "type": "五言",
    "lines": [
      "青青园中葵",
      "朝露待日晞",
      "阳春布德泽",
      "万物生光辉",
      "常恐秋节至",
      "焜黄华叶衰",
      "百川东到海",
      "何时复西归",
      "少壮不努力",
      "老大徒伤悲"
    ],
    "id": "1a4df0804"
  },
  {
    "title": "七步诗",
    "dynasty": "三国",
    "author": "曹植",
    "type": "五言",
    "lines": [
      "煮豆燃豆萁",
      "豆在釜中泣",
      "本是同根生",
      "相煎何太急"
    ],
    "id": "42f443f8c"
  },
  {
    "title": "回乡偶书",
    "dynasty": "唐",
    "author": "贺知章",
    "type": "七言",
    "lines": [
      "少小离家老大回",
      "乡音无改鬓毛衰",
      "儿童相见不相识",
      "笑问客从何处来"
    ],
    "id": "5003a16f2"
  },
  {
    "title": "柳枝词",
    "dynasty": "唐",
    "author": "贺知章",
    "type": "七言",
    "lines": [
      "碧玉妆成一树高",
      "万条垂下绿丝绦",
      "不知细叶谁裁出",
      "二月春风似剪刀"
    ],
    "id": "26d673b89"
  },
  {
    "title": "凉州词",
    "dynasty": "唐",
    "author": "王之涣",
    "type": "七言",
    "lines": [
      "黄河远上白云间",
      "一片孤城万仞山",
      "羌笛何须怨杨柳",
      "春风不度玉门关"
    ],
    "id": "b19904da7"
  },
  {
    "title": "九月九日忆山东兄弟",
    "dynasty": "唐",
    "author": "王维",
    "type": "七言",
    "lines": [
      "独在异乡为异客",
      "每逢佳节倍思亲",
      "遥知兄弟登高处",
      "遍插茱萸少一人"
    ],
    "id": "0bccdf200"
  },
  {
    "title": "鹿柴",
    "dynasty": "唐",
    "author": "王维",
    "type": "五言",
    "lines": [
      "空山不见人",
      "但闻人语响",
      "返景入深林",
      "复照青苔上"
    ],
    "id": "3c7528b4e"
  },
  {
    "title": "相思",
    "dynasty": "唐",
    "author": "王维",
    "type": "五言",
    "lines": [
      "红豆生南国",
      "春来发几枝",
      "愿君多采撷",
      "此物最相思"
    ],
    "id": "166e38bb6"
  },
  {
    "title": "山居秋暝",
    "dynasty": "唐",
    "author": "王维",
    "type": "五言",
    "lines": [
      "空山新雨后",
      "天气晚来秋",
      "明月松间照",
      "清泉石上流",
      "竹喧归浣女",
      "莲动下渔舟",
      "随意春芳歇",
      "王孙自可留"
    ],
    "id": "10b95d6c6"
  },
  {
    "title": "早发白帝城",
    "dynasty": "唐",
    "author": "李白",
    "type": "七言",
    "lines": [
      "朝辞白帝彩云间",
      "千里江陵一日还",
      "两岸猿声啼不住",
      "轻舟已过万重山"
    ],
    "id": "e40200fa0"
  },
  {
    "title": "黄鹤楼送孟浩然之广陵",
    "dynasty": "唐",
    "author": "李白",
    "type": "七言",
    "lines": [
      "故人西辞黄鹤楼",
      "烟花三月下扬州",
      "孤帆远影碧空尽",
      "唯见长江天际流"
    ],
    "id": "9cc006b32"
  },
  {
    "title": "望天门山",
    "dynasty": "唐",
    "author": "李白",
    "type": "七言",
    "lines": [
      "天门中断楚江开",
      "碧水东流至此回",
      "两岸青山相对出",
      "孤帆一片日边来"
    ],
    "id": "49fe96ead"
  },
  {
    "title": "凉州词",
    "dynasty": "唐",
    "author": "王翰",
    "type": "七言",
    "lines": [
      "葡萄美酒夜光杯",
      "欲饮琵琶马上催",
      "醉卧沙场君莫笑",
      "古来征战几人回"
    ],
    "id": "8a72f2341"
  },
  {
    "title": "春夜喜雨",
    "dynasty": "唐",
    "author": "杜甫",
    "type": "五言",
    "lines": [
      "好雨知时节",
      "当春乃发生",
      "随风潜入夜",
      "润物细无声",
      "野径云俱黑",
      "江船火独明",
      "晓看红湿处",
      "花重锦官城"
    ],
    "id": "67dee8f54"
  },
  {
    "title": "绝句",
    "dynasty": "唐",
    "author": "杜甫",
    "type": "七言",
    "lines": [
      "两个黄鹂鸣翠柳",
      "一行白鹭上青天",
      "窗含西岭千秋雪",
      "门泊东吴万里船"
    ],
    "id": "5a3a4105a"
  },
  {
    "title": "枫桥夜泊",
    "dynasty": "唐",
    "author": "张继",
    "type": "七言",
    "lines": [
      "月落乌啼霜满天",
      "江枫渔火对愁眠",
      "姑苏城外寒山寺",
      "夜半钟声到客船"
    ],
    "id": "3de827a71"
  },
  {
    "title": "渔歌子",
    "dynasty": "唐",
    "author": "张志和",
    "type": "七言",
    "lines": [
      "西塞山前白鹭飞",
      "桃花流水鳜鱼肥",
      "青箬笠",
      "绿蓑衣",
      "斜风细雨不须归"
    ],
    "id": "12957132e"
  },
  {
    "title": "寻隐者不遇",
    "dynasty": "唐",
    "author": "贾岛",
    "type": "五言",
    "lines": [
      "松下问童子",
      "言师采药去",
      "只在此山中",
      "云生不知处"
    ],
    "id": "43fad7fa4"
  },
  {
    "title": "游子吟",
    "dynasty": "唐",
    "author": "孟郊",
    "type": "五言",
    "lines": [
      "慈母手中线",
      "游子身上衣",
      "临行密密缝",
      "意恐迟迟归",
      "谁言寸草心",
      "报得三春晖"
    ],
    "id": "91e478f77"
  },
  {
    "title": "悯农",
    "dynasty": "唐",
    "author": "李绅",
    "type": "五言",
    "lines": [
      "锄禾日当午",
      "汗滴禾下土",
      "谁知盘中餐",
      "粒粒皆辛苦"
    ],
    "id": "5af7bf544"
  },
  {
    "title": "江雪",
    "dynasty": "唐",
    "author": "柳宗元",
    "type": "五言",
    "lines": [
      "千山鸟飞绝",
      "万径人踪灭",
      "孤舟蓑笠翁",
      "独钓寒江雪"
    ],
    "id": "8c61abd8c"
  },
  {
    "title": "清明",
    "dynasty": "唐",
    "author": "杜牧",
    "type": "七言",
    "lines": [
      "清明时节雨纷纷",
      "路上行人欲断魂",
      "借问酒家何处有",
      "牧童遥指杏花村"
    ],
    "id": "e0252f5e0"
  },
  {
    "title": "梅花",
    "dynasty": "宋",
    "author": "王安石",
    "type": "五言",
    "lines": [
      "墙角数枝梅",
      "凌寒独自开",
      "遥知不是雪",
      "为有暗香来"
    ],
    "id": "77a7e2b73"
  },
  {
    "title": "鸟鸣涧",
    "dynasty": "唐",
    "author": "王维",
    "type": "五言",
    "lines": [
      "人闲桂花落",
      "夜静春山空",
      "月出惊山鸟",
      "时鸣春涧中"
    ],
    "id": "b981e9cb7"
  },
  {
    "title": "题西林壁",
    "dynasty": "宋",
    "author": "苏轼",
    "type": "七言",
    "lines": [
      "横看成岭侧成峰",
      "远近高低各不同",
      "不识庐山真面目",
      "只缘身在此山中"
    ],
    "id": "d6337e8e6"
  },
  {
    "title": "饮湖上初晴后雨",
    "dynasty": "宋",
    "author": "苏轼",
    "type": "七言",
    "lines": [
      "水光潋滟晴方好",
      "山色空蒙雨亦奇",
      "欲把西湖比西子",
      "淡妆浓抹总相宜"
    ],
    "id": "3ede6e056"
  },
  {
    "title": "惠崇春江晚景",
    "dynasty": "宋",
    "author": "苏轼",
    "type": "七言",
    "lines": [
      "竹外桃花三两枝",
      "春江水暖鸭先知",
      "蒌蒿满地芦芽短",
      "正是河豚欲上时"
    ],
    "id": "052f276a4"
  },
  {
    "title": "六月二十七日望湖楼醉书",
    "dynasty": "宋",
    "author": "苏轼",
    "type": "七言",
    "lines": [
      "黑云翻墨未遮山",
      "白雨跳珠乱入船",
      "卷地风来忽吹散",
      "望湖楼下水如天"
    ],
    "id": "acd9accc4"
  },
  {
    "title": "绝句",
    "dynasty": "宋",
    "author": "李清照",
    "type": "五言",
    "lines": [
      "生当作人杰",
      "死亦为鬼雄",
      "至今思项羽",
      "不肯过江东"
    ],
    "id": "0e26ca306"
  },
  {
    "title": "小池",
    "dynasty": "宋",
    "author": "杨万里",
    "type": "七言",
    "lines": [
      "泉眼无声惜细流",
      "树阴照水爱晴柔",
      "小荷才露尖尖角",
      "早有蜻蜓立上头"
    ],
    "id": "6748e27bb"
  },
  {
    "title": "晓出净慈寺送林子方",
    "dynasty": "宋",
    "author": "杨万里",
    "type": "七言",
    "lines": [
      "毕竟西湖六月中",
      "风光不与四时同",
      "接天莲叶无穷碧",
      "映日荷花别样红"
    ],
    "id": "b15b9744a"
  },
  {
    "title": "游园不值",
    "dynasty": "宋",
    "author": "叶绍翁",
    "type": "七言",
    "lines": [
      "应怜屐齿印苍苔",
      "小扣柴扉久不开",
      "春色满园关不住",
      "一枝红杏出墙来"
    ],
    "id": "da7271768"
  },
  {
    "title": "绝句",
    "dynasty": "宋",
    "author": "志南",
    "type": "七言",
    "lines": [
      "古木阴中系短篷",
      "杖藜扶我过桥东",
      "沾衣欲湿杏花雨",
      "吹面不寒杨柳风"
    ],
    "id": "d6f4a6326"
  },
  {
    "title": "石灰吟",
    "dynasty": "明",
    "author": "于谦",
    "type": "七言",
    "lines": [
      "千锤万凿出深山",
      "烈火焚烧若等闲",
      "粉骨碎身浑不怕",
      "要留清白在人间"
    ],
    "id": "763c0cd97"
  },
  {
    "title": "竹石",
    "dynasty": "清",
    "author": "郑燮",
    "type": "七言",
    "lines": [
      "咬定青山不放松",
      "立根原在破岩中",
      "千磨万击还坚劲",
      "任尔东西南北风"
    ],
    "id": "fb6abce74"
  },
  {
    "title": "舟夜书所见",
    "dynasty": "清",
    "author": "查慎行",
    "type": "五言",
    "lines": [
      "月黑见渔灯",
      "孤光一点萤",
      "微微风簇浪",
      "散作满河星"
    ],
    "id": "823290a34"
  },
  {
    "title": "所见",
    "dynasty": "清",
    "author": "袁枚",
    "type": "五言",
    "lines": [
      "牧童骑黄牛",
      "歌声振林樾",
      "意欲捕鸣蝉",
      "忽然闭口立"
    ],
    "id": "91178a435"
  },
  {
    "title": "村居",
    "dynasty": "清",
    "author": "高鼎",
    "type": "七言",
    "lines": [
      "草长莺飞二月天",
      "拂堤杨柳醉春烟",
      "儿童散学归来早",
      "忙趁东风放纸鸢"
    ],
    "id": "ccab28ede"
  },
  {
    "title": "江南",
    "dynasty": "汉",
    "author": "汉乐府",
    "type": "五言",
    "lines": [
      "江南可采莲",
      "莲叶何田田",
      "鱼戏莲叶间",
      "鱼戏莲叶东",
      "鱼戏莲叶西",
      "鱼戏莲叶南",
      "鱼戏莲叶北"
    ],
    "id": "478135406"
  },
  {
    "title": "风",
    "dynasty": "唐",
    "author": "李峤",
    "type": "五言",
    "lines": [
      "解落三秋叶",
      "能开二月花",
      "过江千尺浪",
      "入竹万竿斜"
    ],
    "id": "d3bd534a6"
  },
  {
    "title": "出塞",
    "dynasty": "唐",
    "author": "王昌龄",
    "type": "七言",
    "lines": [
      "秦时明月汉时关",
      "万里长征人未还",
      "但使龙城飞将在",
      "不教胡马度阴山"
    ],
    "id": "59e75fdea"
  },
  {
    "title": "从军行",
    "dynasty": "唐",
    "author": "王昌龄",
    "type": "七言",
    "lines": [
      "青海长云暗雪山",
      "孤城遥望玉门关",
      "黄沙百战穿金甲",
      "不破楼兰终不还"
    ],
    "id": "622f949d7"
  },
  {
    "title": "芙蓉楼送辛渐",
    "dynasty": "唐",
    "author": "王昌龄",
    "type": "七言",
    "lines": [
      "寒雨连江夜入吴",
      "平明送客楚山孤",
      "洛阳亲友如相问",
      "一片冰心在玉壶"
    ],
    "id": "19b2c96ee"
  },
  {
    "title": "送元二使安西",
    "dynasty": "唐",
    "author": "王维",
    "type": "七言",
    "lines": [
      "渭城朝雨浥轻尘",
      "客舍青青柳色新",
      "劝君更尽一杯酒",
      "西出阳关无故人"
    ],
    "id": "dbd82c698"
  },
  {
    "title": "夜宿山寺",
    "dynasty": "唐",
    "author": "李白",
    "type": "五言",
    "lines": [
      "危楼高百尺",
      "手可摘星辰",
      "不敢高声语",
      "恐惊天上人"
    ],
    "id": "e9d985292"
  },
  {
    "title": "独坐敬亭山",
    "dynasty": "唐",
    "author": "李白",
    "type": "五言",
    "lines": [
      "众鸟高飞尽",
      "孤云独去闲",
      "相看两不厌",
      "只有敬亭山"
    ],
    "id": "4577c482c"
  },
  {
    "title": "赠汪伦",
    "dynasty": "唐",
    "author": "李白",
    "type": "七言",
    "lines": [
      "李白乘舟将欲行",
      "忽闻岸上踏歌声",
      "桃花潭水深千尺",
      "不及汪伦送我情"
    ],
    "id": "56fda6b7a"
  },
  {
    "title": "别董大",
    "dynasty": "唐",
    "author": "高适",
    "type": "七言",
    "lines": [
      "千里黄云白日曛",
      "北风吹雁雪纷纷",
      "莫愁前路无知己",
      "天下谁人不识君"
    ],
    "id": "413ec9bb8"
  },
  {
    "title": "闻官军收河南河北",
    "dynasty": "唐",
    "author": "杜甫",
    "type": "七言",
    "lines": [
      "剑外忽传收蓟北",
      "初闻涕泪满衣裳",
      "却看妻子愁何在",
      "漫卷诗书喜欲狂",
      "白日放歌须纵酒",
      "青春作伴好还乡",
      "即从巴峡穿巫峡",
      "便下襄阳向洛阳"
    ],
    "id": "25b745e1f"
  },
  {
    "title": "小儿垂钓",
    "dynasty": "唐",
    "author": "胡令能",
    "type": "七言",
    "lines": [
      "蓬头稚子学垂纶",
      "侧坐莓苔草映身",
      "路人借问遥招手",
      "怕得鱼惊不应人"
    ],
    "id": "8dfc8a5f2"
  },
  {
    "title": "滁州西涧",
    "dynasty": "唐",
    "author": "韦应物",
    "type": "七言",
    "lines": [
      "独怜幽草涧边生",
      "上有黄鹂深树鸣",
      "春潮带雨晚来急",
      "野渡无人舟自横"
    ],
    "id": "0a190d773"
  },
  {
    "title": "塞下曲",
    "dynasty": "唐",
    "author": "卢纶",
    "type": "五言",
    "lines": [
      "月黑雁飞高",
      "单于夜遁逃",
      "欲将轻骑逐",
      "大雪满弓刀"
    ],
    "id": "6cc804005"
  },
  {
    "title": "早春呈水部张十八员外",
    "dynasty": "唐",
    "author": "韩愈",
    "type": "七言",
    "lines": [
      "天街小雨润如酥",
      "草色遥看近却无",
      "最是一年春好处",
      "绝胜烟柳满皇都"
    ],
    "id": "14fa17e65"
  },
  {
    "title": "悯农",
    "dynasty": "唐",
    "author": "李绅",
    "type": "五言",
    "lines": [
      "春种一粒粟",
      "秋收万颗子",
      "四海无闲田",
      "农夫犹饿死"
    ],
    "id": "c237c4dd3"
  },
  {
    "title": "马诗",
    "dynasty": "唐",
    "author": "李贺",
    "type": "五言",
    "lines": [
      "大漠沙如雪",
      "燕山月似钩",
      "何当金络脑",
      "快走踏清秋"
    ],
    "id": "cc2aefd14"
  },
  {
    "title": "江南春",
    "dynasty": "唐",
    "author": "杜牧",
    "type": "七言",
    "lines": [
      "千里莺啼绿映红",
      "水村山郭酒旗风",
      "南朝四百八十寺",
      "多少楼台烟雨中"
    ],
    "id": "768e72525"
  },
  {
    "title": "过华清宫",
    "dynasty": "唐",
    "author": "杜牧",
    "type": "七言",
    "lines": [
      "长安回望绣成堆",
      "山顶千门次第开",
      "一骑红尘妃子笑",
      "无人知是荔枝来"
    ],
    "id": "af1ef3fbb"
  },
  {
    "title": "夜雨寄北",
    "dynasty": "唐",
    "author": "李商隐",
    "type": "七言",
    "lines": [
      "君问归期未有期",
      "巴山夜雨涨秋池",
      "何当共剪西窗烛",
      "却话巴山夜雨时"
    ],
    "id": "45811b6d2"
  },
  {
    "title": "江上渔者",
    "dynasty": "宋",
    "author": "范仲淹",
    "type": "五言",
    "lines": [
      "江上往来人",
      "但爱鲈鱼美",
      "君看一叶舟",
      "出没风波里"
    ],
    "id": "7b80ad662"
  },
  {
    "title": "泊船瓜洲",
    "dynasty": "宋",
    "author": "王安石",
    "type": "七言",
    "lines": [
      "京口瓜洲一水间",
      "钟山只隔数重山",
      "春风又绿江南岸",
      "明月何时照我还"
    ],
    "id": "c515630bc"
  },
  {
    "title": "元日",
    "dynasty": "宋",
    "author": "王安石",
    "type": "七言",
    "lines": [
      "爆竹声中一岁除",
      "春风送暖入屠苏",
      "千门万户曈曈日",
      "总把新桃换旧符"
    ],
    "id": "4b8b056d0"
  },
  {
    "title": "三衢道中",
    "dynasty": "宋",
    "author": "曾几",
    "type": "七言",
    "lines": [
      "梅子黄时日日晴",
      "小溪泛尽却山行",
      "绿阴不减来时路",
      "添得黄鹂四五声"
    ],
    "id": "08412c9a2"
  },
  {
    "title": "示儿",
    "dynasty": "宋",
    "author": "陆游",
    "type": "七言",
    "lines": [
      "死去元知万事空",
      "但悲不见九州同",
      "王师北定中原日",
      "家祭无忘告乃翁"
    ],
    "id": "d5e3b16c6"
  },
  {
    "title": "有约",
    "dynasty": "宋",
    "author": "赵师秀",
    "type": "七言",
    "lines": [
      "黄梅时节家家雨",
      "青草池塘处处蛙",
      "有约不来过夜半",
      "闲敲棋子落灯花"
    ],
    "id": "192b3ab09"
  },
  {
    "title": "题临安邸",
    "dynasty": "宋",
    "author": "林升",
    "type": "七言",
    "lines": [
      "山外青山楼外楼",
      "西湖歌舞几时休",
      "暖风熏得游人醉",
      "直把杭州作汴州"
    ],
    "id": "2f13b0b05"
  },
  {
    "title": "山行",
    "dynasty": "唐",
    "author": "杜牧",
    "type": "七言",
    "lines": [
      "远上寒山石径斜",
      "白云深处有人家",
      "停车坐爱枫林晚",
      "霜叶红于二月花"
    ],
    "id": "660a33565"
  },
  {
    "title": "赠刘景文",
    "dynasty": "宋",
    "author": "苏轼",
    "type": "七言",
    "lines": [
      "荷尽已无擎雨盖",
      "菊残犹有傲霜枝",
      "一年好景君须记",
      "正是橙黄橘绿时"
    ],
    "id": "0e006466c"
  }
]